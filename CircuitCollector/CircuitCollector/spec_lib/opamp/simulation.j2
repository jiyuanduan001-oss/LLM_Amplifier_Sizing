{% if measure_DC%}
DC temp -40 125 1
* TC meas   
meas dc maxval MAX V(vout6) from=-40 to=125
meas dc minval MIN V(vout6) from=-40 to=125
meas dc avgval AVG V(vout6) from=-40 to=125
meas dc ppavl  PP V(vout6) from=-40 to=125
let TC = ppavl/avgval/165
* Power meas (at user-requested temperature)
meas dc Ivdd_t FIND I(VVDDDC) AT={{temperature|default(27)}}
let Power_ = -1 * Ivdd_t * {{supply_voltage}}
let Power = Power_ * 1e6
* Vos meas (at user-requested temperature)
meas dc vout_t FIND V(vout6) AT={{temperature|default(27)}}
let vos25 = vout_t - {{supply_voltage}} * {{VCM_ratio}}
{# wrdata {{data_DC}} TC Power vos25 #}
print TC Power vos25 > {{data_DC}}.txt
* plot v(vout6)
{% endif %}

{% if measure_AC%}
ac dec 10 0.1 1G
meas ac cm_gain find vdb(cm3) at = 0.1
meas ac dcgain_ find vdb(opout) at = 0.1
let dcgain = abs(dcgain_)
let cmrr = -cm_gain
meas ac gain_bandwidth_product_ when vdb(opout)=0
let gbp = gain_bandwidth_product_*1e-4
meas ac phase_margin find vp(opout) when vdb(opout)=0
meas ac DCPSRp find vdb(ppsr1) at = 0.1
meas ac DCPSRn find vdb(npsr1) at = 0.1
* --- Effective GBW vs measured GBW (gain-plateau detection) ---
* The open-loop 0dB crossing (gain_bandwidth_product_) can be inflated
* by a zero-compensation plateau when Rc is too large.
* Detection: for -20dB/dec roll-off, gain at GBW/10 = +20dB.
* If the LHP zero creates a shelf, the actual gain there is LOWER
* (the slope was already shallow before reaching the check point).
* A deficit means the measured GBW is inflated: the open-loop gain
* only reached 0dB because the shelf extended it beyond the true
* bandwidth. The deficit in dB equals the inflation.
let f_check = gain_bandwidth_product_ / 10
meas ac gain_at_check find vdb(opout) at=f_check
* gain_peaking_dB = deficit from ideal 20dB (0 = healthy, >0 = plateau)
let gain_peaking_dB_raw = 20 - gain_at_check
* Clamp to >= 0 (no penalty for healthy designs)
if gain_peaking_dB_raw > 0
  let gain_peaking_dB = gain_peaking_dB_raw
else
  let gain_peaking_dB = 0
end
* true_GBW: the GBW that a -20dB/dec slope from DC gain would predict.
* true_GBW = 10^(dcgain/20) × f where vdb(opout) = dcgain - 20*log10(f/f_p1)
* Simplified: true_GBW ≈ measured_GBW / 10^(gain_peaking_dB/20)
let true_GBW = gain_bandwidth_product_ / 10 ^ (gain_peaking_dB / 20)
{# print AC specs to file #}
print cm_gain cmrr DCPSRp DCPSRn dcgain_ > {{data_AC}}.txt
print gain_bandwidth_product_ phase_margin gain_peaking_dB true_GBW > {{data_GBW_PM}}.txt
* Save DC gain and GBW for noise integration
let ac_dc_gain_linear = 10 ^ (dcgain / 20)
set ac_dc_gain_str = "$&ac_dc_gain_linear"
set gbw_str = "$&gain_bandwidth_product_"
* plot vdb(opout) vdb(cm3) vdb(ppsr1) vdb(npsr1) vp(opout)
{% endif %}

